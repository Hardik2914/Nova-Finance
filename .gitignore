# Monorepo Root gitignore

# Build and package targets
**/target/
**/dist/
**/dist-ssr/
*.war
*.sar
*.ear
*.class
*.jar

# Dependencies
**/node_modules/
jspm_packages/
web_modules/

# Local Maven Binaries
/maven/

# IDE files
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.classpath
.project
.settings/
.factorypath

# OS specifics
.DS_Store
Thumbs.db

# Logs and temp files
*.log
**/logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Environment local secrets
.env
.env.local
.env.*.local
